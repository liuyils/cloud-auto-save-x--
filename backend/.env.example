REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax

MEDIA_PROXY_IMAGE_CACHE_ENABLED=true
MEDIA_PROXY_IMAGE_CACHE_TTL_SECONDS=86400
MEDIA_PROXY_IMAGE_CACHE_MAX_FILE_BYTES=10485760
MEDIA_PROXY_IMAGE_CACHE_MAX_TOTAL_BYTES=536870912
